# zsh-no-matches-found
unsetopt nomatch

# line navigation (previously provided by oh-my-zsh)
bindkey "^A"  beginning-of-line     # Cmd+Left
bindkey "^E"  end-of-line           # Cmd+Right
bindkey "^[b" backward-word         # Option+Left
bindkey "^[f" forward-word          # Option+Right

# mise - interactive shell support
eval "$(mise activate zsh)"

# tmux/venv
[ -n "$VIRTUAL_ENV" ] && \. "$VIRTUAL_ENV/bin/activate"

# kubectl - bind k alias to kubectl completions
compdef k=kubectl

