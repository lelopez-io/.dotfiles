## [REQUIRED] Essential
brew "eza"
brew "fzf"                     # fuzzy finder, gco + keybindings in dotfiles
brew "git-delta"               # diff pager, used by 02-dotfiles.sh and 05-git.sh
brew "libyaml"                 # ruby build dependency (mise)
brew "mise"
brew "starship"
brew "stow"
brew "tmux"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"
cask "ghostty"

## [REQUIRED] Neovim
brew "neovim"
brew "imagemagick"        # image.nvim
brew "mermaid-cli"        # mermaid diagram rendering
brew "prettierd"          # conform.nvim formatter
brew "ripgrep"            # telescope.nvim live_grep
brew "stylua"             # conform.nvim formatter
brew "tree-sitter-cli"    # nvim-treesitter parser compilation
cask "ungoogled-chromium" # mermaid-cli puppeteer backend

## [OPTIONAL] CLI Tools
brew "jq"
brew "the_silver_searcher"
brew "tree"
# brew "atuin"             # shell history w/ sync, evaluate
# brew "telnet"
# brew "watch"
# brew "wget"
# brew "yamllint"
# brew "yq"

## [OPTIONAL] Git & GitHub
brew "gh"        # extensions managed in 05-git.sh
cask "gitkraken"

## [OPTIONAL] Editors & IDEs
cask "zed"
