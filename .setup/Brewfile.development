## [OPTIONAL] AI Tools
cask "claude-code"

## [OPTIONAL] Cloud & Infrastructure
brew "ansible"
brew "awscli"
brew "hashicorp/tap/terraform"
cask "gcloud-cli"

## [OPTIONAL] Kubernetes
brew "fluxcd/tap/flux"
brew "kubectx"
brew "talhelper"
cask "rancher"

## [OPTIONAL] Secrets & Auth
brew "age"
brew "gnupg"
brew "sops"
cask "1password"
cask "1password-cli"

