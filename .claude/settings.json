{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "osascript -e 'beep 3'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "sx report-usage --client=claude-code",
            "type": "command"
          }
        ],
        "matcher": "Skill|Task|SlashCommand|mcp__.*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "sx install --hook-mode --client=claude-code",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "osascript -e 'beep 3'",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "opus",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(tree:*)",
      "Bash(xargs cat:*)",
      "Bash(flutter:*)",
      "Bash(mise trust:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(go fmt:*)",
      "Bash(go test:*)",
      "Bash(go tool cover:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(rio help:*)",
      "Bash(yarn eslint:*)",
      "Bash(yarn jest:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn start:*)",
      "Bash(yarn test:*)",
      "Bash(yarn typecheck)",
      "Bash(gt checkout:*)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(git -C:*)"
    ]
  }
}