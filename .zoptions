# zsh-no-matches-found
unsetopt nomatch

# emacs keybindings (EDITOR=nvim triggers vi mode, restore emacs line editing)
bindkey -e
# line navigation (previously provided by oh-my-zsh)
bindkey "^A"    beginning-of-line                # Cmd+Left
bindkey "^E"    end-of-line                      # Cmd+Right
bindkey "^[b"   backward-word                    # Option+Left
bindkey "^[f"   forward-word                     # Option+Right
bindkey "^[[A"  history-beginning-search-backward # Up (prefix search)
bindkey "^[[B"  history-beginning-search-forward  # Down (prefix search)

# mise - interactive shell support
eval "$(mise activate zsh)"

# tmux/venv
[ -n "$VIRTUAL_ENV" ] && \. "$VIRTUAL_ENV/bin/activate"

# kubectl - load completions and bind k alias
if (( $+commands[kubectl] )); then
  local _kubectl_comp="${HOME}/.zsh/completions/_kubectl"
  if [[ ! -f "$_kubectl_comp" || "$_kubectl_comp" -ot "$(command -v kubectl)" ]]; then
    kubectl completion zsh > "$_kubectl_comp"
  fi
  compdef k=kubectl
else
  echo "warning: kubectl not found"
fi

